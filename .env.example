# Copy to .env and fill in values.

# Supabase (Postgres + REST)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# Upstash Redis (logs / config overrides)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenRouter (free-tier models supported)
OPENROUTER_API_KEY=
LLM_PRIMARY=deepseek/deepseek-chat-v3-0324:free
LLM_FALLBACK=meta-llama/llama-3.3-70b-instruct:free

# Hunter.io — ~25 free domain searches/month (optional; email finder)
# https://hunter.io → Sign up → API
HUNTER_API_KEY=

# Public base URL of this app (for email open tracking pixels), e.g. https://your-app.onrender.com
APP_PUBLIC_URL=

# Gmail SMTP (same as notifier — for recruiter outreach)
SMTP_EMAIL=
SMTP_APP_PASSWORD=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Applicant profile
APPLICANT_NAME=Your Name
APPLICANT_EMAIL=you@email.com
APPLICANT_PHONE=+91-0000000000
APPLICANT_LOCATION=Bangalore, India
APPLICANT_LINKEDIN=
APPLICANT_GITHUB=
YEARS_EXPERIENCE=3

# Search & pipeline
SEARCH_KEYWORDS=Python Engineer,Backend Developer
SEARCH_LOCATIONS=Remote,Bangalore
SALARY_MIN_INR=1500000
MATCH_THRESHOLD=75
MAX_APPLICATIONS_PER_DAY=15
SCRAPE_INTERVAL_HOURS=6

# Smart filters (comma-separated lists where noted)
EXCLUDE_COMPANIES=
EXCLUDE_KEYWORDS=unpaid internship only,stipend only
MIN_SALARY_INR=1500000
PREFER_COMPANIES=
MAX_EXPERIENCE_REQUIRED=10
WORK_TYPE=any
COMPANY_SIZE=any

# LinkedIn optimizer / resume A/B label written on tailor
TARGET_ROLES=Software Engineer,Backend Developer
RESUME_ACTIVE_VARIANT=base

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
