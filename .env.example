# ── Supabase (free at supabase.com → Settings → Database) ──
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your-anon-public-key-here
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Upstash Redis is OPTIONAL - app works without it, just no live log stream
# Get free at upstash.com if you want the live log panel in dashboard
# ── Upstash Redis (free at upstash.com → REST API tab) ──
UPSTASH_REDIS_REST_URL=https://YOUR_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here

# ── OpenRouter (free at openrouter.ai → Keys tab, no CC needed) ──
OPENROUTER_API_KEY=your-openrouter-api-key-here
LLM_PRIMARY=deepseek/deepseek-chat-v3-0324:free
LLM_FALLBACK=meta-llama/llama-3.3-70b-instruct:free

# ── Telegram (free — message @BotFather → /newbot) ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Gmail SMTP (free — use 2FA App Password, not real password) ──
SMTP_EMAIL=your-email@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password-here

# ── Applicant Profile (replace with your details) ──
APPLICANT_NAME=Your Full Name
APPLICANT_EMAIL=you@example.com
APPLICANT_PHONE=+1-000-000-0000
APPLICANT_LOCATION=City, Country
APPLICANT_LINKEDIN=https://linkedin.com/in/yourprofile
APPLICANT_GITHUB=https://github.com/yourusername
YEARS_EXPERIENCE=4

# ── Job Search Settings ──
SEARCH_KEYWORDS=Python Engineer,Backend Developer,FastAPI Developer,AI Engineer
SEARCH_LOCATIONS=Remote,City Name
SALARY_MIN_INR=1500000
MATCH_THRESHOLD=75
MAX_APPLICATIONS_PER_DAY=15
SCRAPE_INTERVAL_HOURS=6
APPLY_INTERVAL_HOURS=2
DAILY_SUMMARY_HOUR=20

# ── App ──
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=production
